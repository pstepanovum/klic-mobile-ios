<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>aps-environment</key>
    <string>development</string>
    <!-- Shared container + keychain access group (app groups double as keychain access
         groups on iOS) so the KlicShare extension can read the auth tokens. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.klic.mobile.app</string>
    </array>
    <!-- Passkeys (§10.4/§13.10): the RP is klic.pstepanov.dev — its AASA serves
         webcredentials for this app id (the legacy sslip.io entry stays; harmless).
         Universal links (§13.8): applinks for /u/* and /add/* friend links.
         AltStore re-signing may strip this — passkeys degrade with a readable error
         and universal links simply don't open the app (QR scanning still works). -->
    <key>com.apple.developer.associated-domains</key>
    <array>
        <string>webcredentials:klic.pstepanov.dev</string>
        <string>webcredentials:api.89.34.230.2.sslip.io</string>
        <string>applinks:klic.pstepanov.dev</string>
    </array>
</dict>
</plist>
